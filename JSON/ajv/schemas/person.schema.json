{
    "$id": "persona.schema.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Persona",
    "description": "Schema para validar los datos de una persona.",
    "type": "object",
    "properties": {
        "nombre": {
            "type": "string",
            "description": "El nombre de la persona."
        },
        "apellido": {
            "type": "string",
            "description": "El apellido de la persona."
        },
        "edad": {
            "description": "Edad en años. Debe ser igual o mayor que cero.",
            "type": "integer",
            "minimum": 0
        }
    }
}